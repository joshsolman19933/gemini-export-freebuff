# =============================================================================
# Gemini Chat Exporter -- Kornyezeti valtozok sablon
# =============================================================================
# Masold at ezt a fajlt .env neven, es toltsd ki az ertekeket:
#   cp .env.example .env
# =============================================================================

# --- Google Gemini session cookie-k (kotelezo, kiveve auto-cookies mod) ---
# Beszerzes: gemini.google.com -> F12 -> Application -> Cookies

GEMINI_SECURE_1PSID=your_secure_1psid_value_here
GEMINI_SECURE_1PSIDTS=your_secure_1psidts_value_here

# --- Auto-cookie mod (opcionalis) ---
# Ha 1-re allitod, a program automatikusan kiolvassa a cookie-kat a
# bongeszodbol a browser-cookie3 csomag segitsegevel.
# GEMINI_AUTO_COOKIES=1

# --- Export beallitasok (opcionalis) ---
# EXPORT_OUTPUT_DIR=./exports
# EXPORT_DELAY=0.5
