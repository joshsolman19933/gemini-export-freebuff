# =============================================================================
# Gemini Chat Exporter -- Kornyezeti valtozok sablon
# =============================================================================
# Masold at ezt a fajlt .env neven, es toltsd ki az ertekeket:
#   cp .env.example .env
# =============================================================================

# --- Google Gemini session cookie-k (kotelezo, kiveve auto-cookies mod) ---
# Beszerzes: gemini.google.com -> F12 -> Application -> Cookies

GEMINI_SECURE_1PSID=your_secure_1psid_value_here
GEMINI_SECURE_1PSIDTS=your_secure_1psidts_value_here

# --- Auto-cookie mod (opcionalis) ---
# Ha 1-re allitod, a program automatikusan kiolvassa a cookie-kat a
# bongeszodbol a browser-cookie3 csomag segitsegevel.
# GEMINI_AUTO_COOKIES=1

# --- Export beallitasok (opcionalis) ---
# EXPORT_OUTPUT_DIR=./exports
# EXPORT_DELAY=0.5

# --- AI elemzés (opcionális, OpenAI-kompatibilis API) ---
# Szükséges a --ai-analyze kapcsolóhoz és a dashboard AI funkcióihoz.
# Bármilyen OpenAI-kompatibilis API működik (OpenAI, Groq, Ollama, stb.)
# OPENAI_API_KEY=sk-your-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKENS=500

# --- Embedding modell (opcionális, RAG/szemantikus kereséshez) ---
# Alapértelmezett: text-embedding-3-small. Ollama esetén pl.: nomic-embed-text
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Embedding provider (opcionális, lokális vs API) ---
# "auto" (alap): lokálisat próbál először, API-ra fallback
# "local": mindig lokális sentence-transformers modell (offline, nincs API költség)
# "openai" / "ollama" / "gemini": mindig API-alapú embedding
# EMBEDDING_PROVIDER=auto

# --- Lokális embedding modell (opcionális, EMBEDDING_PROVIDER=local esetén) ---
# Alapértelmezett: all-MiniLM-L6-v2 (384 dimenzió, ~80 MB, CPU-n is gyors)
# Alternatívák: all-mpnet-base-v2 (768d, ~420MB), multi-qa-MiniLM-L6-cos-v1 (RAG-ra optimalizált)
# LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- AI provider választás (opcionális) ---
# 7 támogatott provider: openai, anthropic, gemini, groq, together, deepseek, ollama
# Ha nincs beállítva, auto-detektálás az OPENAI_BASE_URL alapján (default: openai)
# AI_PROVIDER=openai

# --- Anthropic Claude API (opcionális, AI_PROVIDER=anthropic esetén) ---
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Google Gemini API (opcionális, AI_PROVIDER=gemini esetén) ---
# GEMINI_API_KEY=your-google-ai-studio-key-here

# --- Dashboard hozzáférés védelem (opcionális) ---
# Ha beállítod, a /dashboard és /api/* endpointok csak ezzel a tokennel érhetők el.
# Használat: Authorization: Bearer <token> header vagy ?token=<token> query param.
# Ha üres, a dashboard nyitott marad (backward compat).
# DASHBOARD_ACCESS_TOKEN=my-secret-token

# --- Prompt template könyvtár (opcionális) ---
# Egyedi AI prompt template-ek elérési útja. Alapértelmezett: ./prompts
# PROMPTS_DIR=./prompts

# --- Naplózás (opcionális) ---
# Lehetséges értékek: DEBUG, INFO, WARNING, ERROR. Alapértelmezett: INFO
# LOG_LEVEL=INFO
